{
  "name": "product-ai-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck && npm run lint && npm run test",
    "dev:api": "npm run dev:api --workspace @product/server",
    "dev:runner": "npm run dev:runner --workspace @product/server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "sdk:sri": "node scripts/sri.mjs",
    "sdk:smoke": "node scripts/smoke-sdk.mjs",
    "sdk:size": "node scripts/check-bundle-size.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "admin:seed": "npm run admin:seed --workspace @product/server --"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
